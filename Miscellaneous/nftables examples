# ═══════════════════════════════════════════════════════════
# inet family handles both IPv4 and IPv6 in a single table
# ═══════════════════════════════════════════════════════════
table inet test_filter {

    # Named set for dynamically blackholing IPs
    # Add IPs at runtime: nft add element inet test_filter blackhole { 1.2.3.4 }
    # Add with timeout: nft add element inet test_filter blackhole { 1.2.3.4 timeout 1h }
    set blackhole {
        type ipv4_addr
        flags timeout
        timeout 24h
    }

    # ── Input chain (incoming traffic) ────────────────
    chain input {
        # Set default policy: drop everything not explicitly allowed
        type filter hook input priority 0; policy drop;

        # Allow loopback traffic
        iif lo accept

        # Drop traffic not on the expected interface (anti-spoof)
        # iif != "eth0" drop

        # ── Connection tracking ──────────────────────────
        # Fast-path: accept packets belonging to established connections
        ct state established,related accept

        # Drop packets with invalid connection tracking state
        ct state invalid drop

        # ── Blackhole set ────────────────────────────────
        # Drop all traffic from IPs in the blackhole set
        ip saddr @blackhole drop

        # ── SYN flood protection ─────────────────────────
        # Limit new TCP SYN packets to 25/sec per source IP
        # Excess SYN packets are dropped to prevent connection table exhaustion
        tcp flags syn ct state new \
            meter syn_flood { ip saddr limit rate over 25/second burst 50 packets } \
            drop

        # ── UDP flood protection ─────────────────────────
        # Limit UDP packets to 50/sec per source IP
        ip protocol udp \
            meter udp_flood { ip saddr limit rate over 50/second burst 100 packets } \
            drop

        # ── ICMP rate limiting ────────────────────────────
        # Allow echo requests at 5/sec; drop excess
        icmp type echo-request limit rate 5/second burst 10 packets accept
        icmp type echo-request drop

        # Allow essential ICMP types (path MTU discovery, etc.)
        icmp type { destination-unreachable, time-exceeded, parameter-problem } accept

        # ── Global new connection rate limit ──────────────
        # Limit total new connections to 200/sec across all sources
        ct state new limit rate over 200/second burst 600 packets drop

        # ── Allowed service ports ─────────────────────────
        # Only permit traffic to these specific TCP ports
        tcp dport { 22, 80, 443 } accept

        # Uncomment additional ports as needed:
        # tcp dport { 25, 587 } accept       # SMTP
        # tcp dport 3306 accept               # MySQL
        # udp dport 53 accept                 # DNS
        # udp dport { 27015-27030 } accept    # Game servers

        # ── Logging (optional) ───────────────────────────
        # Log dropped packets (limit to avoid log flooding during attacks)
        limit rate 5/minute log prefix "nft-drop: " level warn

        # Everything else is dropped by the chain policy
    }

    # ── Forward chain ─────────────────────────────────
    chain forward {
        type filter hook forward priority 0; policy drop;
    }

    # ── Output chain ──────────────────────────────────
    chain output {
        type filter hook output priority 0; policy accept;
    }
}

