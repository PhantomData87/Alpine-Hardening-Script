# Chain logic & jumps
table ip filter{
	chain INPUT {
		type filter hook input priority filter; policy accept;
		tcp dport 80 counter jump CHAIN1
		tcp dport 80 counter jump CHAIN2
		tcp dport 80 counter goto CHAIN3
		tcp dport 80 counter goto CHAIN4
	}
	chain CHAIN1 {
		counter return
		counter # not seen
	}
	chain CHAIN2 {
		counter drop
		counter # not seen, due to evaluating drop
	}
	chain CHAIN3 {
		counter
	}
	chain CHAIN4 {
		counter # Ignoring chain2, this is never seen since we 'goto' chain3
	}
}

