# Idea of chains without vertex map
table ip filter{
	chain INPUT {
		type filter hook input priority filter; policy accept;
		ip protocol tcp jump CHAIN_TCP
		ip protocol udp jump CHAIN_UDP
		ip protocol icmp jump CHAIN_ICMP
	}
	chain CHAIN_TCP {
		counter
	}
	chain CHAIN_UDP {
		counter
	}
	chain CHAIN_ICMP {
		counter
	}
}

# Idea of chains with a vertex map
table ip filter{
	chain INPUT {
		type filter hook input priority filter; policy accept;
		ip protocol vmap {
			tcp : jump CHAIN_TCP
			udp : jump CHAIN_UDP
			icmp: jump CHAIN_ICMP
		}
	}
	chain CHAIN_TCP {
		counter
	}
	chain CHAIN_UDP {
		counter
	}
	chain CHAIN_ICMP {
		counter
	}
}

# Idea of chains with a vertex map concatenated
table ip filter{
	chain INPUT {
		type filter hook input priority filter; policy accept;
		iifname . ip protocol vmap {
			eth0 . tcp : jump CHAIN_TCP
			eth0 . udp : jump CHAIN_UDP
			eth0 . icmp: jump CHAIN_ICMP
		}
	}
	chain CHAIN_TCP {
		counter
	}
	chain CHAIN_UDP {
		counter
	}
	chain CHAIN_ICMP {
		counter
	}
}

# Idea of chains with a vertex map simplification
table ip filter{
	chain INPUT {
		type filter hook input priority filter; policy accept;
		ct state vmap { establish : accept, related : accept, invalid : drop}
	}
}

