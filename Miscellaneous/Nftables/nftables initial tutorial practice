# dnat (Destination network address translation)
table ip nat {
	chain PREROUTING {
		type nat hook prerouting priority dstnat; policy accept;
		tcp dport 80 dnat to 192.168.0.1:8080  # Outbound server http port -> Local listening:8080 interface (not recommended for localhost)
	}
}

# dnat mangle (Destination network address translation)
table ip nat {
	chain PREROUTING {
		type nat hook output priority mangle; policy accept;
		tcp dport 80 dnat to 192.168.0.1:8080  # Outbound client http port -> Local listening:8080 interface instead of output server port
	}
}

# Global Rate limit
table ip mytab {
	chain INPUT {
		type filter hook input priority filter; policy accept;
		ip protocol icmp icmp type echo-request limit rate 1/second accept
		ip protocol icmp icmp type echo-request counter drop
	}
}

# Individual Rate limit (meter)
table ip mytab {
	chain INPUT {
		type filter hook input priority filter; policy accept;
		ip protocol icmp icmp type echo-request meter meter_name_icmp { ip saddr limit rate 1/second } accept
		ip protocol icmp icmp type echo-request counter drop
	}
}
over # Instead of limit rate 1/second, we have limit rate over 1/second for wanting connections above 1 second
