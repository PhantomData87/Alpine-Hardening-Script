# Syn flood protection (burst)
table ip mytab {
	chain INPUT {
		type filter hook input priority filter; policy accept;
		tcp flags syn / fin,syn,rst,ack jump SYN_FLOOD
	}
	chain SYN_FLOOD {
		limit rate 25/second burst 50 packets counter return
		counter drop
	}
}


